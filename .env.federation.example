# Конфиг федерации (скопируй в .env). Используется docker-compose.traefik.yml.

# Домены банков (Traefik роутит по Host). Для локали оставь *.localhost.
VBANK_DOMAIN=vbank.localhost
ABANK_DOMAIN=abank.localhost
SBANK_DOMAIN=sbank.localhost

# Креды твоей команды (POST /auth/bank-token). Определяют person_id клиентов:
# при team218 будут team218-1, team218-2, ...
TEAM_CLIENT_ID=team218
TEAM_CLIENT_SECRET=change-me-team-secret

# Сид: сколько клиентов и стартовый баланс
SEED_CLIENTS=2
SEED_BALANCE=1000000

# Секреты (одинаковые для всех банков федерации)
SECRET_KEY=federation-shared-secret-change-me
INTERBANK_SHARED_SECRET=interbank-secret-change-me
